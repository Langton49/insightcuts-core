# Twelve Labs — video indexing & gesture search
TWELVE_LABS_API=tlk_...

# OpenAI — GPT-4o for narration & insights
CHATGPT_API=sk-proj-...

# ElevenLabs — text-to-speech
ELEVEN_LABS_API=sk_...

# Server port (default: 3001)
PORT=3001

# Storage paths — override to point at a Railway volume mount (default: ./uploads, ./output)
UPLOADS_DIR=/data/uploads
OUTPUT_DIR=/data/output

# Slack OAuth — create an app at https://api.slack.com/apps
# Required scopes: files:write, chat:write, channels:read, groups:read
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=https://insightcuts-core-production.up.railway.app/api/slack/callback
