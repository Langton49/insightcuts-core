{
  "name": "insightcuts-core",
  "version": "0.1.0",
  "description": "InsightCuts core pipeline — Twelve Labs gesture search + FFmpeg assembly, no UI",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:client": "npm run dev --prefix client",
    "build": "npm install --prefix client && npm run build --prefix client",
    "build:client": "npm run build --prefix client",
    "start": "NODE_ENV=production tsx src/server.ts",
    "cli": "tsx scripts/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "mammoth": "^1.11.0",
    "multer": "^2.1.0",
    "openai": "^6.25.0",
    "pdf-parse": "^2.4.5",
    "twelvelabs-js": "^1.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
